# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.

# Google OAuth 2.0 Client ID (safe to be semi-public, but keep out of git)
# Get yours at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Groq API key — NEVER expose this in the browser or commit it.
# Used ONLY by netlify/functions/summarize.ts (server-side).
# For local dev run: netlify dev   (starts Vite + functions on one port)
# Set on Netlify: Site settings → Environment variables → GROQ_API_KEY
# Get yours at https://console.groq.com
# NOTE: VITE_ prefix intentionally omitted so it is NOT bundled into the client.
GROQ_API_KEY=your_groq_api_key_here

# EmailJS (optional — only needed for email notifications)
# Get yours at https://www.emailjs.com
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_TASK_CREATED=your_task_created_template_id
VITE_EMAILJS_TEMPLATE_TASK_DONE=your_task_done_template_id
# Template variables: to_name, to_email, from_name, project_name, project_description, message
VITE_EMAILJS_TEMPLATE_PROJECT_INVITE=your_project_invite_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
