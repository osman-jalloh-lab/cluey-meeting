# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — NEVER commit real credentials.

# ─── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web Application type)
# These are used SERVER-SIDE only (Netlify Functions). Do NOT add VITE_ prefix.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Required redirect URIs to register in Google Cloud Console:
#   Production:  https://parawi.com/auth/callback
#   Local dev:   http://localhost:8888/auth/callback

# ─── Groq AI ──────────────────────────────────────────────────────────────────
# Used ONLY by netlify/functions/summarize.ts (server-side)
# For local dev run: netlify dev
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
