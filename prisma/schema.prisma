generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String           @id @default(cuid())
  name           String?
  email          String?          @unique
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  sessions       Session[]
  connectedAccounts ConnectedAccount[]
  emailCaches    EmailCache[]
  tasks          Task[]
  notes          Note[]
  aiConversations AiConversation[]
  aiMemories     AiMemory[]
  apiUsageLogs   ApiUsageLog[]
  agentTasks     AgentTask[]
  agentMessages  AgentMessage[]
  jobLeads       JobLead[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ConnectedAccount {
  id                     String      @id @default(cuid())
  userId                 String
  provider               String      @default("google")
  emailAddress           String
  accountLabel           String      @default("Personal")
  accessTokenEncrypted   String?
  refreshTokenEncrypted  String?
  tokenExpiresAt         DateTime?
  scopes                 String?
  isActive               Boolean     @default(true)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailCaches            EmailCache[]
  tasks                  Task[]

  @@unique([userId, emailAddress])
}

model EmailCache {
  id                 String           @id @default(cuid())
  userId             String
  connectedAccountId String
  gmailMessageId     String
  threadId           String?
  from               String
  to                 String?
  subject            String?
  snippet            String?
  bodyText           String?
  receivedAt         DateTime?
  isUnread           Boolean          @default(true)
  isImportant        Boolean          @default(false)
  hasAttachment      Boolean          @default(false)
  summary            String?
  priority           String?          @default("normal")
  needsReply         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([connectedAccountId, gmailMessageId])
}

model Task {
  id                 String            @id @default(cuid())
  userId             String
  title              String
  description        String?
  priority           String            @default("normal")
  status             String            @default("pending")
  dueDate            DateTime?
  sourceType         String?
  sourceAccountId    String?
  sourceEmailId      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAccount      ConnectedAccount? @relation(fields: [sourceAccountId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiConversation {
  id        String      @id @default(cuid())
  userId    String
  title     String      @default("New Conversation")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  provider       String?
  model          String?
  createdAt      DateTime       @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model ApiUsageLog {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  model         String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  estimatedCost Float    @default(0)
  action        String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentTask {
  id               String         @id @default(cuid())
  userId           String
  title            String
  description      String?
  assignedTo       String
  createdBy        String         @default("CEO Controller Agent")
  priority         String         @default("normal")
  status           String         @default("open")
  source           String?
  dueDate          DateTime?
  carryForward     Boolean        @default(false)
  requiresApproval Boolean        @default(false)
  result           String?
  agentNotes       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         AgentMessage[]
}

model AgentMessage {
  id          String     @id @default(cuid())
  userId      String
  fromAgent   String
  toAgent     String?
  taskId      String?
  message     String
  messageType String     @default("update")
  status      String     @default("sent")
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        AgentTask? @relation(fields: [taskId], references: [id])
}

model JobLead {
  id                    String   @id @default(cuid())
  userId                String
  title                 String
  company               String
  location              String?
  source                String?
  jobUrl                String?
  matchScore            Int      @default(0)
  matchReason           String?
  requiredSkills        String?
  matchedSkills         String?
  missingSkills         String?
  workAuthNotes         String?
  status                String   @default("Found")
  resumeVersion         String?
  coverLetterVersion    String?
  createdBy             String   @default("Career Advisor Agent")
  requiresApproval      Boolean  @default(true)
  nextAction            String?
  deadline              DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
